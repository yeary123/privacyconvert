# Copy to .env.local and fill in your values. Never commit .env.local.
# See docs/ENV_KEYS.md for full documentation.

# Site URL (sharing, sitemap, auth redirect)
NEXT_PUBLIC_SITE_URL=https://localhost:3000

# Contact email domain (e.g. support@your-domain.com; optional, for forks)
# NEXT_PUBLIC_CONTACT_DOMAIN=your-domain.com

# Supabase (auth / users)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# PayPal (payments)
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_ID=
# PAYPAL_SECRET=
# PAYPAL_WEBHOOK_ID=
# PAYPAL_SANDBOX=true

# Newsletter (choose one: Brevo / ConvertKit / Buttondown)
# BREVO_API_KEY=
# BREVO_LIST_ID=
# CONVERTKIT_API_KEY=
# CONVERTKIT_FORM_ID=
# BUTTONDOWN_API_KEY=

# Google Analytics (optional; leave unset to disable)
# NEXT_PUBLIC_GA_ID=
